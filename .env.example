# === Required ===

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GoHighLevel API key and location ID
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_ghl_location_id_here

# Protects admin/management endpoints
ADMIN_API_KEY=your_admin_key_here

# === Optional ===

# Active vertical (must match a filename in verticals/ without .yaml)
ACTIVE_VERTICAL=real_estate

# GHL calendar ID (for verticals with booking_enabled: true)
GHL_CALENDAR_ID=your_calendar_id_here

# Claude model override
CLAUDE_MODEL=claude-sonnet-4-5-20250514

# Webhook signature verification
GHL_WEBHOOK_SECRET=your_webhook_secret_here

ENVIRONMENT=development
LOG_LEVEL=INFO
